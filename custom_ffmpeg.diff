+#define decode_significance_skip decode_significance_skip_x86
+static int decode_significance_skip_x86(CABACContext *c, int max_coeff,
+                                   uint8_t *significant_coeff_ctx_base,
+                                   x86_reg last_off){
+    void *end= significant_coeff_ctx_base + max_coeff - 1;
+    int bit;
+    x86_reg coeff_count;
+    x86_reg counter = 0;
+
+#ifdef BROKEN_RELOCATIONS
+    void *tables;
+    __asm__ volatile(
+        "lea    " MANGLE(ff_h264_cabac_tables) ", %0      \n\t"
+        : "=&r"(tables)
+        : NAMED_CONSTRAINTS_ARRAY(ff_h264_cabac_tables)
+    );
+#endif
+
+    __asm__ volatile(
+        "3:                                     \n\t"
+
+        /* Decode significance flag for current coefficient position */
+        BRANCHLESS_GET_CABAC("%4", "%q4", "(%1)", "%3", "%w3",
+                             "%5", "%q5", "%k0", "%b0",
+                             "%c9(%6)", "%c10(%6)",
+                             AV_STRINGIFY(H264_NORM_SHIFT_OFFSET),
+                             AV_STRINGIFY(H264_LPS_RANGE_OFFSET),
+                             AV_STRINGIFY(H264_MLPS_STATE_OFFSET),
+                             "%11")
+
+        "test $1, %4                            \n\t"
+        " jnz 6f                                \n\t"
+
+        /* HOT PATH: not significant — fall through */
+        "4:                                     \n\t"
+        "add  $1, %1                            \n\t"
+        "cmp  %7, %1                            \n\t"
+        " jb 3b                                 \n\t"
+
+        /* End: implicit significant at last position */
+        "add  $1, %2                            \n\t"  /* counter++ (REGISTER!) */
+        "jmp 5f                                 \n\t"
+
+        /* COLD: significant coefficient */
+        "6:                                     \n\t"
+        "add  %8, %1                            \n\t"
+
+        BRANCHLESS_GET_CABAC("%4", "%q4", "(%1)", "%3", "%w3",
+                             "%5", "%q5", "%k0", "%b0",
+                             "%c9(%6)", "%c10(%6)",
+                             AV_STRINGIFY(H264_NORM_SHIFT_OFFSET),
+                             AV_STRINGIFY(H264_LPS_RANGE_OFFSET),
+                             AV_STRINGIFY(H264_MLPS_STATE_OFFSET),
+                             "%11")
+
+        "sub  %8, %1                            \n\t"
+        "add  $1, %2                            \n\t"  /* counter++ (REGISTER!) */
+
+        "test $1, %4                            \n\t"
+        " jnz 5f                                \n\t"
+
+        "jmp 4b                                 \n\t"
+
+        "5:                                     \n\t"
+        "mov  %k2, %k0                           \n\t"
+ 
+        : "=&q"(coeff_count), "+r"(significant_coeff_ctx_base),
+          "+r"(counter),                                /* "+r" not "+m"! */
+          "+&r"(c->low), "=&r"(bit), "+&r"(c->range)
+        : "r"(c), "m"(end), "m"(last_off),
+          "i"(offsetof(CABACContext, bytestream)),
+          "i"(offsetof(CABACContext, bytestream_end))
+          TABLES_ARG
+        : "%"FF_REG_c, "memory"
+    );
+    return coeff_count;
+}
